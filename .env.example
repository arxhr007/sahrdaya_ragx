# Groq model and keys
GROQ_MODEL_ID=openai/gpt-oss-120b
# Comma-separated list for busy-key failover
GROQ_API_KEYS=gsk_key_one,gsk_key_two
# Optional single key fallback
GROQ_API_KEY=

# Optional: pin one key per replica in docker-compose.nginx.yml
# Use different org keys if available.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# API runtime
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Session and load controls
SESSION_TTL_SECONDS=3600
MAX_CONCURRENT_REQUESTS=4
QUEUE_WAIT_SECONDS=20

# Groq free-tier guardrails (override if your org limits differ)
GROQ_RPM_LIMIT=30
GROQ_TPM_LIMIT=8000
GROQ_RPD_LIMIT=1000
GROQ_TPD_LIMIT=200000

# Continuation policy
MAX_CONTINUATIONS=3

# Key pool behavior
KEY_FAILURE_THRESHOLD=2
KEY_DEFAULT_COOLDOWN_SECONDS=15
